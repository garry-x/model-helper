#!/usr/bin/env bash
set -euo pipefail

# model-helper bash wrapper — auto-activates the venv and runs the CLI
# Usage: ./model-helper <command> [args...]

# Follow symlinks to find the real project directory (portable macOS/Linux)
RESOLVED="$0"
while [ -L "$RESOLVED" ]; do
    TARGET="$(readlink "$RESOLVED")"
    case "$TARGET" in
        /*) RESOLVED="$TARGET" ;;
        *)  RESOLVED="$(dirname "$RESOLVED")/$TARGET" ;;
    esac
done
SCRIPT_DIR="$(cd "$(dirname "$RESOLVED")" && pwd)"
VENV_PYTHON="${SCRIPT_DIR}/venv/bin/python"

if [[ ! -f "${VENV_PYTHON}" ]]; then
    echo "Error: virtualenv not found at ${SCRIPT_DIR}/venv" >&2
    echo "Run: python3 -m venv venv && pip install -e ." >&2
    exit 1
fi

exec "${VENV_PYTHON}" -m model_helper.cli.main "$@"
